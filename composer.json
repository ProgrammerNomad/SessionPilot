{
    "name": "programmer-nomad/sessionpilot",
    "description": "Open-source session & activity monitoring for logged-in WordPress users.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Shiv Singh",
            "email": "shiv@srapsware.com",
            "homepage": "https://github.com/ProgrammerNomad",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "roots/acorn": "^4.0",
        "whichbrowser/parser": "^2.1",
        "mobiledetect/mobiledetectlib": "^3.74"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.8",
        "wp-coding-standards/wpcs": "^3.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "ProgrammerNomad\\SessionPilot\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProgrammerNomad\\SessionPilot\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=PSR12 app/",
        "phpcbf": "phpcbf --standard=PSR12 app/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    },
    "extra": {
        "acorn": {
            "providers": [
                "ProgrammerNomad\\SessionPilot\\Providers\\SessionPilotServiceProvider"
            ]
        }
    }
}
